{{!< default}}

{{#author}}
<div class="author-archive-wrap">
  <header class="author-archive-header">
    {{#if profile_image}}
      <img class="author-archive-avatar" src="{{img_url profile_image size="s"}}" alt="{{name}}" />
    {{/if}}
    <h1 class="author-archive-name">{{name}}</h1>
    {{#if bio}}<p class="author-archive-bio">{{bio}}</p>{{/if}}
    <p class="author-archive-count">{{plural ../pagination.total empty="వ్యాసాలు లేవు" singular="% వ్యాసం" plural="% వ్యాసాలు"}}</p>
  </header>

  <div class="posts-list">
    {{#foreach posts}}
      {{> "post-card"}}
    {{/foreach}}
  </div>

  {{pagination}}
</div>
{{/author}}
