{{!< default}}

{{#author}}
<section class="archive-wrap container">
    <header class="archive-header author-header">
        {{#if profile_image}}<img class="author-avatar" src="{{img_url profile_image size="s"}}" alt="{{name}}" />{{/if}}
        <h1 class="archive-title">{{name}}</h1>
        {{#if bio}}<p class="archive-desc">{{bio}}</p>{{/if}}
        <p class="archive-count">{{plural ../pagination.total empty="వ్యాసాలు లేవు" singular="% వ్యాసం" plural="% వ్యాసాలు"}}</p>
    </header>

    <div class="story-grid archive-grid">
        {{#foreach posts}}
            {{> "post-card"}}
        {{/foreach}}
    </div>

    {{pagination}}
</section>
{{/author}}
