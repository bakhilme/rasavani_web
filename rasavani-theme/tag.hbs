{{!< default}}

{{#tag}}
<section class="archive-wrap container">
    <header class="archive-header">
        {{#if feature_image}}<img class="archive-cover" src="{{img_url feature_image size="l"}}" alt="{{name}}" />{{/if}}
        <h1 class="archive-title">{{name}}</h1>
        {{#if description}}<p class="archive-desc">{{description}}</p>{{/if}}
        <p class="archive-count">{{plural ../pagination.total empty="వ్యాసాలు లేవు" singular="% వ్యాసం" plural="% వ్యాసాలు"}}</p>
    </header>

    <div class="story-grid archive-grid">
        {{#foreach posts}}
            {{> "post-card"}}
        {{/foreach}}
    </div>

    {{pagination}}
</section>
{{/tag}}
