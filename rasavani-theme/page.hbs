{{!< default}}

{{#post}}
<article class="page-full container {{page_class}}">
    {{#if @page.show_title_and_feature_image}}
        <header class="page-full-header">
            <h1 class="page-full-title">{{title}}</h1>
        </header>

        {{#if feature_image}}
            <figure class="post-full-image">
                <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" />
            </figure>
        {{/if}}
    {{/if}}

    <section class="gh-content page-full-content">
        {{content}}
    </section>
</article>
{{/post}}
