{{!< default}}

<div class="home-wrap">

  {{#foreach posts limit="1"}}
  {{! ── FEATURED POST ── }}
  <section class="featured-wrap">
    <article class="featured-post {{post_class}}">
      <a href="{{url}}" class="featured-post-link">
        {{#if feature_image}}
          <div class="featured-image-wrap">
            <img
              class="featured-image"
              src="{{img_url feature_image size="l"}}"
              alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            />
            <div class="featured-overlay"></div>
          </div>
        {{else}}
          <div class="featured-image-wrap featured-no-image">
            <div class="featured-overlay"></div>
          </div>
        {{/if}}
        <div class="featured-content">
          {{#primary_tag}}<span class="featured-tag">{{name}}</span>{{/primary_tag}}
          <h1 class="featured-title">{{title}}</h1>
          {{#if custom_excerpt}}
            <p class="featured-excerpt">{{custom_excerpt}}</p>
          {{else}}
            <p class="featured-excerpt">{{excerpt words="30"}}</p>
          {{/if}}
          <span class="featured-read-more">చదవండి →</span>
        </div>
      </a>
    </article>
  </section>
  {{/foreach}}

  {{! ── POSTS + SIDEBAR ── }}
  <div class="home-body">
    <div class="posts-list">
      {{#foreach posts limit="all" from="2"}}
        {{> "post-card"}}
      {{/foreach}}
    </div>

    <aside class="home-sidebar">
      {{! Tags / Categories }}
      <div class="sidebar-widget">
        <h3 class="widget-title">విభాగాలు</h3>
        <ul class="widget-tags" role="list">
          {{#get "tags" limit="12" include="count.posts"}}
            {{#foreach tags}}
              <li><a href="{{url}}" class="widget-tag-link">{{name}} <span class="tag-count">{{count.posts}}</span></a></li>
            {{/foreach}}
          {{/get}}
        </ul>
      </div>

      {{! Recent posts }}
      <div class="sidebar-widget">
        <h3 class="widget-title">తాజా వ్యాసాలు</h3>
        <ul class="widget-recent" role="list">
          {{#get "posts" limit="5"}}
            {{#foreach posts}}
              <li class="widget-recent-item">
                <a href="{{url}}" class="widget-recent-link">
                  {{#if feature_image}}
                    <img class="widget-recent-img" src="{{img_url feature_image size="xs"}}" alt="{{title}}" loading="lazy" />
                  {{/if}}
                  <span class="widget-recent-title">{{title}}</span>
                </a>
              </li>
            {{/foreach}}
          {{/get}}
        </ul>
      </div>

      {{! Subscribe }}
      <div class="sidebar-widget sidebar-subscribe">
        <h3 class="widget-title">చందా అవ్వండి</h3>
        <p class="widget-subscribe-text">రోజువారీ అప్‌డేట్స్ మీ inbox కి పొందండి</p>
        {{#if @member}}
          <p class="widget-subscribed">🙏 మీరు చందా చేసుకున్నారు!</p>
        {{else}}
          <form data-members-form="subscribe" class="subscribe-form">
            <input class="subscribe-input" type="email" data-members-email placeholder="Email చిరునామా..." required />
            <button type="submit" class="subscribe-btn">చందా 🙏</button>
          </form>
        {{/if}}
      </div>
    </aside>
  </div>

  {{pagination}}

</div>
